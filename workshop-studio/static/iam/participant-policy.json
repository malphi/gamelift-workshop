{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DriveCloudFormation",
      "Effect": "Allow",
      "Action": "cloudformation:*",
      "Resource": [
        "arn:aws:cloudformation:*:*:stack/PixelRush*/*",
        "arn:aws:cloudformation:*:*:stack/CDKToolkit/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": ["us-east-1", "us-west-2", "ap-northeast-1", "ap-southeast-1"]
        }
      }
    },
    {
      "Sid": "CdkAssetBuckets",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::cdk-*",
        "arn:aws:s3:::cdk-*/*",
        "arn:aws:s3:::pixelrush*",
        "arn:aws:s3:::pixelrush*/*"
      ]
    },
    {
      "Sid": "GameLiftComputeCalls",
      "Effect": "Allow",
      "Action": [
        "gamelift:RegisterCompute",
        "gamelift:DeregisterCompute",
        "gamelift:GetComputeAuthToken"
      ],
      "Resource": "arn:aws:gamelift:*:*:fleet/*"
    },
    {
      "Sid": "CdkBootstrapSsmParams",
      "Effect": "Allow",
      "Action": [
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:AddTagsToResource"
      ],
      "Resource": "arn:aws:ssm:*:*:parameter/cdk-bootstrap/*"
    },
    {
      "Sid": "CdkBootstrapEcr",
      "Effect": "Allow",
      "Action": "ecr:*",
      "Resource": "arn:aws:ecr:*:*:repository/cdk-*"
    },
    {
      "Sid": "SsmSessionStart",
      "Effect": "Allow",
      "Action": "ssm:StartSession",
      "Resource": [
        "arn:aws:ec2:*:*:instance/*",
        "arn:aws:ssm:*:*:document/AWS-StartSSHSession",
        "arn:aws:ssm:*:*:document/SSM-SessionManagerRunShell"
      ]
    },
    {
      "Sid": "SsmSessionManage",
      "Effect": "Allow",
      "Action": [
        "ssm:TerminateSession",
        "ssm:ResumeSession"
      ],
      "Resource": "arn:aws:ssm:*:*:session/*"
    },
    {
      "Sid": "CdkStackRoles",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:TagRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy"
      ],
      "Resource": [
        "arn:aws:iam::*:role/cdk-*",
        "arn:aws:iam::*:role/PixelRush*"
      ]
    },
    {
      "Sid": "PassRolesToWorkshopServices",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::*:role/cdk-*",
        "arn:aws:iam::*:role/PixelRush*"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": [
            "cloudformation.amazonaws.com",
            "gamelift.amazonaws.com",
            "lambda.amazonaws.com",
            "ec2.amazonaws.com"
          ]
        }
      }
    },
    {
      "Sid": "AssumeCdkBootstrapRoles",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Resource": "arn:aws:iam::*:role/cdk-*"
    },
    {
      "Sid": "ReadOnlyAcrossWorkshopServices",
      "Effect": "Allow",
      "Action": [
        "cloudformation:Describe*",
        "cloudformation:List*",
        "cloudformation:Get*",
        "cloudformation:ValidateTemplate",
        "gamelift:Describe*",
        "gamelift:List*",
        "lambda:Get*",
        "lambda:List*",
        "dynamodb:Describe*",
        "dynamodb:List*",
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "apigateway:GET",
        "sns:Get*",
        "sns:List*",
        "cloudfront:Get*",
        "cloudfront:List*",
        "logs:Describe*",
        "logs:Get*",
        "logs:FilterLogEvents",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*",
        "ec2:Describe*",
        "ec2:GetConsole*",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:DescribeSessions",
        "ssm:GetConnectionStatus",
        "ecr:Describe*",
        "ecr:List*",
        "ecr:GetAuthorizationToken",
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer",
        "s3:List*",
        "s3:GetBucketLocation",
        "iam:List*",
        "iam:Get*",
        "servicecatalog:ListApplications",
        "servicecatalog:GetApplication",
        "resource-groups:ListGroups",
        "tag:GetResources",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    }
  ]
}
