{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WorkshopServices",
      "Effect": "Allow",
      "Action": [
        "gamelift:*",
        "cloudformation:*",
        "s3:*",
        "lambda:*",
        "apigateway:*",
        "dynamodb:*",
        "sns:*",
        "cloudfront:*",
        "logs:*",
        "cloudwatch:*",
        "ec2:Describe*",
        "ec2:GetConsole*",
        "ssm:StartSession",
        "ssm:TerminateSession",
        "ssm:ResumeSession",
        "ssm:DescribeSessions",
        "ssm:GetConnectionStatus",
        "ecr:*",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CdkBootstrapRoles",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:TagRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy"
      ],
      "Resource": [
        "arn:aws:iam::*:role/cdk-*",
        "arn:aws:iam::*:role/PixelRush*"
      ]
    },
    {
      "Sid": "PassRolesToWorkshopServices",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::*:role/cdk-*",
        "arn:aws:iam::*:role/PixelRush*"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": [
            "cloudformation.amazonaws.com",
            "gamelift.amazonaws.com",
            "lambda.amazonaws.com",
            "ec2.amazonaws.com"
          ]
        }
      }
    },
    {
      "Sid": "CdkDeployViaBootstrapRoles",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Resource": "arn:aws:iam::*:role/cdk-*"
    },
    {
      "Sid": "IamRead",
      "Effect": "Allow",
      "Action": [
        "iam:List*",
        "iam:Get*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ConsoleHomeWidgets",
      "Effect": "Allow",
      "Action": [
        "servicecatalog:ListApplications",
        "servicecatalog:GetApplication",
        "resource-groups:ListGroups",
        "tag:GetResources"
      ],
      "Resource": "*"
    }
  ]
}
